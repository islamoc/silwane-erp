{
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/build",
  "installCommand": "npm install && cd frontend && npm install",
  "regions": ["cdg1"],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/serverless.js"
    },
    {
      "src": "/health",
      "dest": "/api/serverless.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
